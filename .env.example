# ── LLM Providers ──────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY_2=your_secondary_gemini_api_key_here

GROQ_API_KEY=your_groq_api_key_here
GROQ_API_KEY_2=your_secondary_groq_api_key_here

OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_API_KEY_2=your_secondary_openrouter_api_key_here

NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_API_KEY_2=your_secondary_nvidia_api_key_here

OSM_API_KEY=your_osm_api_key_here

# ── LLM Routing (change per environment) ───────────────
PRIMARY_MODEL=gemini/gemini-2.5-flash-lite
FAST_MODEL=gemini/gemini-3.1-flash-lite-preview

FALLBACK_MODEL_1=openai/deepseek-ai/deepseek-v4-flash
FALLBACK_MODEL_2=gemini/gemini-3.1-flash-lite-preview
FALLBACK_MODEL_3=openai/minimaxai/minimax-m2.7
FALLBACK_MODEL_4=groq/llama-3.3-70b-versatile

# ── RAG Eval / RAGAS judge ──────────────────────────────
# Provider options: groq | nvidia | gemini | osmapi
JUDGE_PROVIDER=osmapi

# Model options (match provider above):
# groq:    llama-3.3-70b-versatile
# osmapi:  qwen3.5-397b-a17b | qwen3.5-122b-a10b
# gemini:  gemini-3.1-flash-lite-preview | gemma-4-31b-it
JUDGE_MODEL=osmapi/qwen3.5-397b-a17b

# Restrict eval to a single jurisdiction (leave unset for all):
# EVAL_JURISDICTION=KARNATAKA

# ── Reranker ────────────────────────────────────────────
RERANKER_MODEL=ms-marco-MiniLM-L-12-v2
RERANKER_SCORE_GAP=0.95

# ── Embeddings ──────────────────────────────────────────
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSION=768
OLLAMA_BASE_URL=http://localhost:11434
HF_TOKEN=your_huggingface_token_here

# ── PostgreSQL + pgvector ───────────────────────────────
# (Neon in production, Docker locally)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=civicsetu
POSTGRES_USER=civicsetu
POSTGRES_PASSWORD=civicsetu_dev

# ── Neo4j (AuraDB in production, Docker locally) ────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=civicsetu_dev

# ── FastAPI ─────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_ENV=development
ALLOWED_ORIGINS=http://localhost:3000
API_KEY=civicsetu-dev-key-change-in-prod

# ── Observability ───────────────────────────────────────
PHOENIX_HOST=localhost
PHOENIX_PORT=6006

# ── Ingestion ───────────────────────────────────────────
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed
LOG_LEVEL=INFO
