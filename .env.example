# ── LLM Providers ──────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── LLM Routing (change per environment) ───────────────
PRIMARY_MODEL=gemini/gemini-2.5-flash-lite
FALLBACK_MODEL_1=groq/llama-3.3-70b-versatile
FALLBACK_MODEL_2=openrouter/meta-llama/llama-3.3-70b-instruct:free
LOCAL_MODEL=ollama/mistral

# ── Embeddings ──────────────────────────────────────────
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSION=768
OLLAMA_BASE_URL=http://localhost:11434

# ── PostgreSQL + pgvector ───────────────────────────────
# (Neon in production, Docker locally)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=civicsetu
POSTGRES_USER=civicsetu
POSTGRES_PASSWORD=civicsetu_dev

# ── Neo4j (AuraDB in production, Docker locally) ────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ── HuggingFace (optional) ──────────────────────────────
HF_TOKEN=

# ── FastAPI ─────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_ENV=development

# ── Observability ───────────────────────────────────────
PHOENIX_HOST=localhost
PHOENIX_PORT=6006

# ── Ingestion ───────────────────────────────────────────
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed
LOG_LEVEL=INFO
